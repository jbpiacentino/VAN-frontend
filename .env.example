# Strapi host only (no trailing slash), e.g. http://10.1.5.125:8080
VITE_STRAPI_BASE_URL=https://cms.example.com

# Strapi read-only API token
VITE_STRAPI_API_TOKEN=replace_with_your_token

# Optional: write token used by the seed script (falls back to VITE_STRAPI_API_TOKEN)
VITE_STRAPI_FULL_ACCESS_TOKEN=replace_with_full_access_token

# Strapi v5 REST prefix (default: /api)
VITE_STRAPI_API_PREFIX=/api

# Strapi single type API ID for the landing page content
VITE_STRAPI_LANDING_SINGLE_TYPE=landing-page
