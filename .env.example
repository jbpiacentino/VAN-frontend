# Strapi host only (no trailing slash), e.g. http://10.1.5.125:8080
# Nuxt runtime uses NUXT_PUBLIC_STRAPI_BASE_URL first, then falls back to VITE_STRAPI_BASE_URL.
NUXT_PUBLIC_STRAPI_BASE_URL=https://cms.example.com
VITE_STRAPI_BASE_URL=https://cms.example.com

# Strapi read-only API token
VITE_STRAPI_API_TOKEN=replace_with_your_token

# Optional: write token used by the seed script (falls back to VITE_STRAPI_API_TOKEN)
VITE_STRAPI_FULL_ACCESS_TOKEN=replace_with_full_access_token

# Strapi v5 REST prefix (default: /api)
VITE_STRAPI_API_PREFIX=/api

# Strapi single type API ID for the landing page content
VITE_STRAPI_LANDING_SINGLE_TYPE=landing-page

# Access gate toggle (true/false). Missing or false disables protection.
PROTECTED_ACCESS=false

# Access gate password (used only when PROTECTED_ACCESS=true)
PROTECTED_ACCESS_PWD=yourpasswordhere

# Grist integration for Solution Guide lead capture
# Base URL can be self-hosted Grist or https://docs.getgrist.com
GRIST_BASE_URL=https://docs.getgrist.com
GRIST_API_KEY=replace_with_grist_api_key
GRIST_DOC_ID=replace_with_grist_doc_id
GRIST_TABLE_ID=SolutionGuideLeads
